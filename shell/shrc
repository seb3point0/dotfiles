# ─── Shared interactive shell config ───────────────────────────
# Sourced by both .zshrc and .bashrc.
# Keep everything here POSIX/bash/zsh compatible.

# ─── Ensure login paths are loaded ─────────────────────────────
# Handles non-login shells, manual source, and tmux panes
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) [ -f ~/.profile ] && . ~/.profile ;;
esac

# ─── Editor ────────────────────────────────────────────────────
export EDITOR='nvim'

# ─── bat (Debian/Ubuntu ships it as batcat) ───────────────────
command -v bat >/dev/null 2>&1 || alias bat='batcat'
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export MANROFFOPT="-c"

# ─── eza aliases (replaces ls) ─────────────────────────────────
alias ls='eza --icons --group-directories-first'
alias ll='eza --icons --group-directories-first -la'
alias la='eza --icons --group-directories-first -a'
alias lt='eza --icons --group-directories-first --tree --level=2'

# ─── Claude Code ───────────────────────────────────────────────
alias claudex='claude --dangerously-skip-permissions'

# ─── zoxide (smarter cd) ───────────────────────────────────────
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init "$(basename "$SHELL")")"

# ─── fzf defaults ──────────────────────────────────────────────
export FZF_DEFAULT_COMMAND='rg --files --hidden --glob "!.git"'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --exclude .git'
export FZF_DEFAULT_OPTS="
  --color=fg:#D8DEE9,bg:#2E3440,hl:#88C0D0
  --color=fg+:#ECEFF4,bg+:#434C5E,hl+:#8FBCBB
  --color=info:#EBCB8B,prompt:#81A1C1,pointer:#BF616A
  --color=marker:#A3BE8C,spinner:#B48EAD,header:#88C0D0
"

# ─── Auto-attach tmux ─────────────────────────────────────────
# Attach to existing session or create one. Skips if already in
# tmux, running in a non-interactive script, or inside VS Code.
if command -v tmux >/dev/null 2>&1 \
    && [ -z "${TMUX:-}" ] \
    && [ -z "${VSCODE_RESOLVING_ENVIRONMENT:-}" ] \
    && [ "$TERM_PROGRAM" != "vscode" ] \
    && [ -t 0 ]; then
  tmux attach-session 2>/dev/null || tmux new-session
fi
