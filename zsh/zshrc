# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export TERM="xterm-256color"

# Homebrew
if [[ -f /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Path to your Oh My Zsh installation
export ZSH="$HOME/.oh-my-zsh"

# Powerlevel10k theme (loaded by oh-my-zsh)
ZSH_THEME="powerlevel10k/powerlevel10k"
DEFAULT_USER=$(whoami)

# Let tmux handle window titles
DISABLE_AUTO_TITLE="true"

# Enable command auto-correction
ENABLE_CORRECTION="true"
unsetopt correct_all

# Show red dots whilst waiting for completion
COMPLETION_WAITING_DOTS="true"

# Plugins
plugins=(git z zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

# Preferred editor
export EDITOR='nvim'
export CLAUDECODE=0

# ls colors — Gruvbox palette
# dir=bold blue, symlink=bold cyan, exec=bold green, pipe=bold yellow, socket=bold red
export LSCOLORS="ExGxBxDxCxExExBxCxFxEx"

# Local bin
export PATH="$HOME/.local/bin:$PATH"

# Use ripgrep for fzf if available
if command -v rg &>/dev/null; then
  export FZF_DEFAULT_COMMAND='rg --files --hidden -g "!{.git,node_modules}"'
fi

# Load fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Colorized man pages
export MANROFFOPT='-c'
export LESS_TERMCAP_mb=$(tput bold; tput setaf 2)
export LESS_TERMCAP_md=$(tput bold; tput setaf 6)
export LESS_TERMCAP_me=$(tput sgr0)
export LESS_TERMCAP_so=$(tput bold; tput setaf 3; tput setab 4)
export LESS_TERMCAP_se=$(tput rmso; tput sgr0)
export LESS_TERMCAP_us=$(tput smul; tput bold; tput setaf 7)
export LESS_TERMCAP_ue=$(tput rmul; tput sgr0)
export LESS_TERMCAP_mr=$(tput rev)
export LESS_TERMCAP_mh=$(tput dim)

# Useful aliases
alias myip='curl -s ifconfig.me'

# eza — modern ls replacement
if command -v eza &>/dev/null; then
  alias ls='eza --icons'
  alias l='eza -1 --icons'
  alias ll='eza -lh --icons --git'
  alias la='eza -lah --icons --git'
  alias lt='eza --tree --icons'
  alias lta='eza --tree --icons -a'
else
  alias ll='ls -lah'
  alias la='ls -A'
  alias l='ls -CF'
fi

# Claude Code
alias claudex='claude --dangerously-skip-permissions --teammate-mode in-process'

# Docker shortcuts
alias dps='docker ps'
alias dpsa='docker ps -a'
alias dlogs='docker logs -f'
alias dexec='docker exec -it'

# Tmux window naming for SSH, mosh, and Claude Code
if [[ -n "$TMUX" ]]; then
  ssh() {
    local host="" skip_next=0
    for arg in "$@"; do
      if (( skip_next )); then skip_next=0; continue; fi
      case "$arg" in
        -[bcDEeFIiJLlmOopQRSWw]) skip_next=1 ;;
        -*) ;;
        *) host="${arg#*@}"; break ;;
      esac
    done
    [[ -n "$host" ]] && tmux rename-window "󰌘 ${host}"
    command ssh "$@"
    tmux set-window-option automatic-rename on
  }

  mosh() {
    local host="" skip_next=0
    for arg in "$@"; do
      if (( skip_next )); then skip_next=0; continue; fi
      case "$arg" in
        --ssh=*|--port=*|--predict=*|--family=*) ;;
        --*) ;;
        -*) skip_next=1 ;;
        *) host="${arg#*@}"; break ;;
      esac
    done
    [[ -n "$host" ]] && tmux rename-window "󰌘 ${host}"
    command mosh "$@"
    tmux set-window-option automatic-rename on
  }

  claude() {
    tmux rename-window "claude"
    command claude "$@"
    tmux set-window-option automatic-rename on
  }

  # Server-side: when a mosh client connects into this machine and zsh starts
  # inside tmux, name the window after the hostname (mirrors SSH behaviour).
  _is_mosh() {
    local pid=$PPID
    while [[ $pid -gt 1 ]]; do
      local name=$(ps -o comm= -p "$pid" 2>/dev/null | tr -d ' ')
      [[ "$name" == "mosh-server" ]] && return 0
      local ppid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
      [[ "$ppid" == "$pid" || -z "$ppid" ]] && break
      pid=$ppid
    done
    return 1
  }
  _is_mosh && tmux rename-window "$(hostname -s)"
fi

# Auto-attach to tmux session when opening a terminal
if command -v tmux &>/dev/null && [[ -z "$TMUX" && -z "$INSIDE_EMACS" && -z "$VSCODE_PID" ]]; then
  tmux attach -t default 2>/dev/null || tmux new-session -s default >/dev/null 2>&1
fi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Machine-specific overrides (paths, env vars, secrets, etc.)
# This file is not tracked by git — create it with anything local to this machine.
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
